<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@color/material_dynamic_secondary50"
        tools:ignore="ScrollViewSize">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dibujando Plantillas"
            android:background="@color/material_dynamic_primary80"
            android:textSize="24sp"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Plantilla con Scroll"
            android:background="@color/material_dynamic_neutral_variant20"
            android:textColor="@color/white"
            android:textSize="24sp"
            android:textFontWeight="@android:integer/config_longAnimTime"
            tools:ignore="HardcodedText,UnusedAttribute" />

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aceptar"
            android:layout_gravity="center_horizontal"
            android:background="@color/material_dynamic_secondary50"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 1"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 2"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 3"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 4"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
    </LinearLayout>
</ScrollView>