<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/material_dynamic_secondary50"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to Kotlin Xml!"
        android:background="@color/white"
        tools:ignore="HardcodedText" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dibujando Plantillas"
        android:background="@color/material_dynamic_primary80"
        tools:ignore="HardcodedText" />

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aceptar"
        android:layout_gravity="center_horizontal"
        android:background="@color/material_dynamic_secondary50"
        tools:ignore="HardcodedText"
        android:layout_margin="16dp"
        android:padding="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="end|center_horizontal">

        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 1"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 2"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 3"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar 4"
            android:background="@color/material_dynamic_primary10"
            tools:ignore="HardcodedText"
            android:layout_margin="16dp"
            android:padding="16dp"/>
    </LinearLayout>
</LinearLayout>